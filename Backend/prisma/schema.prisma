// ─────────────────────────────────────────────────────────────────────────────
// Prisma schema — WE District 323 A2
// Provider : Supabase Postgres
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// CLUBS
// ─────────────────────────────────────────────────────────────────────────────
model Club {
  id          String    @id @default(uuid())
  clubId      String    @unique @map("club_id")
  name        String
  description String?
  // president kept as Json for now — single-value object, no relational queries needed yet
  president   Json?
  images      String[]
  coverImage  String?   @map("cover_image")
  logo        String?
  established DateTime?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations (after Phase 4 events migration)
  events      Event[]
  users       User[]

  @@map("clubs")
}

// ─────────────────────────────────────────────────────────────────────────────
// EVENTS  (Phase 4: currently still JSONB in clubs.events — table created empty)
// ─────────────────────────────────────────────────────────────────────────────
model Event {
  id          String    @id @default(uuid())
  clubId      String    @map("club_id")
  title       String
  description String?
  date        DateTime?
  location    String?
  category    String?
  coverImage  String?   @map("cover_image")
  images      String[]
  isFeatured  Boolean   @default(false) @map("is_featured")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  club        Club      @relation(fields: [clubId], references: [clubId], onDelete: Cascade)

  @@index([clubId])
  @@index([category])
  @@index([date])
  @@map("events")
}

// ─────────────────────────────────────────────────────────────────────────────
// PROJECTS
// ─────────────────────────────────────────────────────────────────────────────
model Project {
  id        String        @id @default(uuid())
  slug      String        @unique
  title     String
  subtitle  String?
  isActive  Boolean       @default(true) @map("is_active")
  sortOrder Int           @default(0) @map("sort_order")

  items     ProjectItem[]

  @@map("projects")
}

model ProjectItem {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  clubId      String?  @map("club_id")
  description String?
  imageUrl    String?  @map("image_url")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// SITE CONTENT  (CMS key-value store for Landing, About, etc.)
// ─────────────────────────────────────────────────────────────────────────────
model SiteContent {
  key         String   @id
  value       Json
  updatedAt   DateTime @updatedAt @map("updated_at")
  updatedBy   String?  @map("updated_by")

  @@map("site_content")
}

// ─────────────────────────────────────────────────────────────────────────────
// USERS  (shadow table — synced from auth.users via Supabase trigger in Phase 6)
// auth decisions still go through Supabase Auth; this table is for Prisma queries
// ─────────────────────────────────────────────────────────────────────────────
model User {
  id        String   @id          // matches auth.users.id (UUID)
  email     String   @unique
  username  String?
  role      String   @default("club")
  clubId    String?  @map("club_id")
  createdAt DateTime @default(now()) @map("created_at")

  club      Club?    @relation(fields: [clubId], references: [clubId], onDelete: SetNull)

  @@map("users")
}
